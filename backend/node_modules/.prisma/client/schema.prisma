// Prisma Schema for Manufacturing ERP
// ~80 tables covering 13 modules

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════
// AUTH & RBAC
// ═══════════════════════════════════════════

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  roles       UserRole[]
  createdDocs AuditLog[]
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          Int      @id @default(autoincrement())
  module      String
  action      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@unique([module, action])
}

model UserRole {
  id     Int  @id @default(autoincrement())
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id])
  role   Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String
  entityId  Int?
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// ═══════════════════════════════════════════
// MODULE 1: SALES MANAGEMENT
// ═══════════════════════════════════════════

model Customer {
  id            Int       @id @default(autoincrement())
  name          String
  gstin         String?
  stateCode     String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  contactPerson String?
  phone         String?
  email         String?
  creditPeriod  Int       @default(30)
  reminderMode  String    @default("Moderate") // Strict/Moderate/Lenient
  isActive      Boolean   @default(true)
  createdBy     Int?
  updatedBy     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  inquiries       Inquiry[]
  quotations      Quotation[]
  saleOrders      SaleOrder[]
  invoices        Invoice[]
  receiptVouchers SalesReceiptVoucher[]
}

model Inquiry {
  id          Int       @id @default(autoincrement())
  inquiryNo   String    @unique
  customerId  Int
  inquiryDate DateTime  @default(now())
  salesPerson String?
  status      String    @default("New") // New, Processing, Quoted, Lost
  remarks     String?
  isActive    Boolean   @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  customer   Customer      @relation(fields: [customerId], references: [id])
  items      InquiryItem[]
  quotations Quotation[]
}

model InquiryItem {
  id           Int       @id @default(autoincrement())
  inquiryId    Int
  productId    Int
  quantity     Float
  targetPrice  Float?
  netAvailable Float?
  deliveryDate DateTime?

  inquiry Inquiry @relation(fields: [inquiryId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Quotation {
  id           Int       @id @default(autoincrement())
  quoteNo      String    @unique
  inquiryId    Int?
  customerId   Int
  quoteDate    DateTime  @default(now())
  validUntil   DateTime
  paymentTerms String?
  totalAmount  Decimal   @default(0)
  status       String    @default("Draft") // Draft, Sent, Accepted, Rejected
  isActive     Boolean   @default(true)
  createdBy    Int?
  updatedBy    Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  inquiry    Inquiry?        @relation(fields: [inquiryId], references: [id])
  customer   Customer        @relation(fields: [customerId], references: [id])
  items      QuotationItem[]
  saleOrders SaleOrder[]
}

model QuotationItem {
  id          Int      @id @default(autoincrement())
  quotationId Int
  productId   Int
  quantity    Decimal
  rate        Decimal
  gstPercent  Decimal  @default(18)
  total       Decimal
  createdAt   DateTime @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
}

model SaleOrder {
  id              Int       @id @default(autoincrement())
  soNo            String    @unique
  quotationId     Int?
  customerId      Int
  customerPoNo    String?
  customerPoDate  DateTime?
  billingAddress  String?
  shippingAddress String?
  totalAmount     Decimal   @default(0)
  status          String    @default("Pending") // Pending, Dispatched, Closed
  isActive        Boolean   @default(true)
  createdBy       Int?
  updatedBy       Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  quotation      Quotation?       @relation(fields: [quotationId], references: [id])
  customer       Customer         @relation(fields: [customerId], references: [id])
  items          SaleOrderItem[]
  dispatchAdvice DispatchAdvice[]
  invoices       Invoice[]
}

model SaleOrderItem {
  id          Int      @id @default(autoincrement())
  saleOrderId Int
  productId   Int
  quantity    Decimal
  rate        Decimal
  gstPercent  Decimal  @default(18)
  total       Decimal
  status      String   @default("Pending") // Pending, Dispatched, Closed
  createdAt   DateTime @default(now())

  saleOrder SaleOrder @relation(fields: [saleOrderId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
}

model DispatchAdvice {
  id            Int       @id @default(autoincrement())
  dispatchNo    String    @unique
  saleOrderId   Int
  transporterId Int?
  vehicleNo     String?
  driverName    String?
  dispatchDate  DateTime  @default(now())
  status        String    @default("Pending") // Pending, Dispatched, Delivered
  isActive      Boolean   @default(true)
  createdBy     Int?
  updatedBy     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  saleOrder   SaleOrder    @relation(fields: [saleOrderId], references: [id])
  transporter Transporter? @relation(fields: [transporterId], references: [id])
}

model Invoice {
  id            Int       @id @default(autoincrement())
  invoiceNo     String    @unique
  saleOrderId   Int?
  customerId    Int
  invoiceDate   DateTime  @default(now())
  dueDate       DateTime
  placeOfSupply String?
  ewayBillNo    String?
  taxableValue  Decimal   @default(0)
  cgstAmount    Decimal   @default(0)
  sgstAmount    Decimal   @default(0)
  igstAmount    Decimal   @default(0)
  roundOff      Decimal   @default(0)
  grandTotal    Decimal   @default(0)
  status        String    @default("Unpaid") // Unpaid, Partial, Paid, Overdue
  isActive      Boolean   @default(true)
  createdBy     Int?
  updatedBy     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  saleOrder      SaleOrder?            @relation(fields: [saleOrderId], references: [id])
  customer       Customer              @relation(fields: [customerId], references: [id])
  items          InvoiceItem[]
  reminders      CollectionReminder[]
  communications CommunicationLog[]
  receipts       SalesReceiptVoucher[]
}

model InvoiceItem {
  id         Int      @id @default(autoincrement())
  invoiceId  Int
  productId  Int
  quantity   Decimal
  rate       Decimal
  gstPercent Decimal  @default(18)
  cgst       Decimal  @default(0)
  sgst       Decimal  @default(0)
  igst       Decimal  @default(0)
  total      Decimal
  createdAt  DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model CollectionReminder {
  id          Int       @id @default(autoincrement())
  invoiceId   Int
  triggerType String // T-7, T-3, T-0, Overdue
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("Pending") // Pending, Sent, Failed
  createdAt   DateTime  @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model CommunicationLog {
  id              Int      @id @default(autoincrement())
  invoiceId       Int?
  channel         String // Email, WhatsApp
  sentAt          DateTime @default(now())
  status          String   @default("Sent") // Sent, Delivered, Read, Failed
  messageTemplate String?
  recipient       String?
  createdAt       DateTime @default(now())

  invoice Invoice? @relation(fields: [invoiceId], references: [id])
}

model SalesReceiptVoucher {
  id          Int       @id @default(autoincrement())
  receiptNo   String    @unique
  invoiceId   Int?
  customerId  Int
  receiptDate DateTime  @default(now())
  amount      Decimal
  paymentMode String // Cheque, NEFT, RTGS, Cash
  referenceNo String?
  remarks     String?
  isActive    Boolean   @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  invoice  Invoice? @relation(fields: [invoiceId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
}

// ═══════════════════════════════════════════
// MODULE 2: PURCHASE MANAGEMENT
// ═══════════════════════════════════════════

model Vendor {
  id            Int       @id @default(autoincrement())
  name          String
  gstin         String?
  stateCode     String?
  address       String?
  city          String?
  state         String?
  contactPerson String?
  phone         String?
  email         String?
  isActive      Boolean   @default(true)
  createdBy     Int?
  updatedBy     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  purchaseOrders  PurchaseOrder[]
  grns            GRN[]
  purchaseBills   PurchaseBill[]
  paymentVouchers PurchasePaymentVoucher[]
}

model MaterialIndent {
  id          Int       @id @default(autoincrement())
  indentNo    String    @unique
  requestDate DateTime  @default(now())
  department  String?
  priority    String    @default("Medium") // High, Medium, Low
  status      String    @default("Pending") // Pending, Approved, Ordered
  isActive    Boolean   @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  items MaterialIndentItem[]
}

model MaterialIndentItem {
  id               Int   @id @default(autoincrement())
  materialIndentId Int
  productId        Int
  currentStock     Float @default(0)
  requestedQty     Float

  materialIndent MaterialIndent @relation(fields: [materialIndentId], references: [id])
  product        Product        @relation(fields: [productId], references: [id])
}

model PurchaseOrder {
  id          Int       @id @default(autoincrement())
  poNo        String    @unique
  vendorId    Int
  poDate      DateTime  @default(now())
  validUntil  DateTime?
  totalAmount Decimal   @default(0)
  status      String    @default("Draft") // Draft, Sent, Partial, Closed
  isActive    Boolean   @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  vendor    Vendor              @relation(fields: [vendorId], references: [id])
  items     PurchaseOrderItem[]
  schedules PurchaseSchedule[]
  grns      GRN[]
}

model PurchaseOrderItem {
  id              Int       @id @default(autoincrement())
  purchaseOrderId Int
  productId       Int
  quantity        Decimal
  rate            Decimal
  expectedDate    DateTime?
  total           Decimal
  createdAt       DateTime  @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}

model PurchaseSchedule {
  id              Int      @id @default(autoincrement())
  purchaseOrderId Int
  expectedDate    DateTime
  followUpStatus  String   @default("On-Time") // On-Time, Delayed
  remarks         String?
  createdAt       DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

model GRN {
  id              Int       @id @default(autoincrement())
  grnNo           String    @unique
  purchaseOrderId Int?
  vendorId        Int
  vendorChallanNo String?
  gateEntryDate   DateTime  @default(now())
  vehicleNo       String?
  status          String    @default("Pending IQC") // Pending IQC, Passed, Rejected
  isActive        Boolean   @default(true)
  createdBy       Int?
  updatedBy       Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  purchaseOrder    PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  vendor           Vendor            @relation(fields: [vendorId], references: [id])
  items            GRNItem[]
  iqcRecords       IQCRecord[]
  materialReceipts MaterialReceipt[]
}

model GRNItem {
  id        Int   @id @default(autoincrement())
  grnId     Int
  productId Int
  quantity  Float

  grn     GRN     @relation(fields: [grnId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model IQCRecord {
  id          Int      @id @default(autoincrement())
  grnId       Int
  productId   Int
  totalQty    Float
  sampleSize  Float
  acceptedQty Float
  rejectedQty Float
  visualCheck String? // Pass/Fail
  dimCheck    String? // Pass/Fail
  remarks     String?
  status      String   @default("Pending") // Pending, Passed, Failed
  isActive    Boolean  @default(true)
  createdBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  grn     GRN     @relation(fields: [grnId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model MaterialReceipt {
  id              Int      @id @default(autoincrement())
  receiptNo       String   @unique
  grnId           Int
  storageLocation String?
  batchNo         String?
  isActive        Boolean  @default(true)
  createdBy       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  grn   GRN                   @relation(fields: [grnId], references: [id])
  items MaterialReceiptItem[]
}

model MaterialReceiptItem {
  id                Int   @id @default(autoincrement())
  materialReceiptId Int
  productId         Int
  quantity          Float

  materialReceipt MaterialReceipt @relation(fields: [materialReceiptId], references: [id])
  product         Product         @relation(fields: [productId], references: [id])
}

model PurchaseBill {
  id              Int       @id @default(autoincrement())
  billNo          String    @unique
  vendorId        Int
  vendorInvoiceNo String?
  invoiceDate     DateTime
  taxableValue    Decimal   @default(0)
  gstAmount       Decimal   @default(0)
  totalAmount     Decimal   @default(0)
  status          String    @default("Unpaid") // Unpaid, Paid
  isActive        Boolean   @default(true)
  createdBy       Int?
  updatedBy       Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  vendor Vendor @relation(fields: [vendorId], references: [id])
}

model PurchasePaymentVoucher {
  id          Int       @id @default(autoincrement())
  voucherNo   String    @unique
  vendorId    Int
  paymentDate DateTime  @default(now())
  amount      Decimal
  bankAccount String?
  paymentMode String? // Cheque, NEFT, RTGS
  referenceNo String?
  isActive    Boolean   @default(true)
  createdBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  vendor Vendor @relation(fields: [vendorId], references: [id])
}

// ═══════════════════════════════════════════
// MODULE 3: PRODUCTION MANAGEMENT
// ═══════════════════════════════════════════

model Product {
  id                  Int       @id @default(autoincrement())
  code                String    @unique
  name                String
  category            String? // Raw Material, Finished Good, Semi-Finished
  unit                String    @default("PCS")
  hsnCode             String?
  gstPercent          Float     @default(18)
  currentStock        Float     @default(0)
  blockedStock        Float     @default(0)
  reorderLevel        Float     @default(0)
  lastPurchasePrice   Float     @default(0)
  productionDays      Int       @default(7)
  manHoursPerUnit     Float     @default(0)
  machineHoursPerUnit Float     @default(0)
  isActive            Boolean   @default(true)
  createdBy           Int?
  updatedBy           Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  bomHeaders           BOMHeader[]
  bomItems             BOMItem[]
  routingTables        RoutingTable[]
  inquiryItems         InquiryItem[]
  quotationItems       QuotationItem[]
  saleOrderItems       SaleOrderItem[]
  invoiceItems         InvoiceItem[]
  materialIndentItems  MaterialIndentItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  grnItems             GRNItem[]
  iqcRecords           IQCRecord[]
  materialReceiptItems MaterialReceiptItem[]
  warehouseStocks      WarehouseStock[]
  materialIssueItems   MaterialIssueItem[]
  productionReports    ProductionReport[]
  jobOrderItems        JobOrderItem[]
}

model BOMHeader {
  id        Int      @id @default(autoincrement())
  productId Int
  bomNo     String   @unique
  version   String   @default("1.0")
  isActive  Boolean  @default(true)
  createdBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product   @relation(fields: [productId], references: [id])
  items   BOMItem[]
}

model BOMItem {
  id          Int     @id @default(autoincrement())
  bomHeaderId Int
  productId   Int // raw material or component
  qtyPerUnit  Float
  unit        String  @default("PCS")
  processName String? // e.g. Cutting, Welding

  bomHeader BOMHeader @relation(fields: [bomHeaderId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
}

model RoutingTable {
  id            Int     @id @default(autoincrement())
  productId     Int
  operationNo   Int
  operationName String
  machineName   String?
  manHours      Float   @default(0)
  machineHours  Float   @default(0)
  setupTime     Float   @default(0)

  product Product @relation(fields: [productId], references: [id])
}

model ProductionRouteCard {
  id          Int       @id @default(autoincrement())
  routeCardNo String    @unique
  batchNo     String?
  productId   Int
  planQty     Float
  actualQty   Float     @default(0)
  scrapQty    Float     @default(0)
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("Open") // Open, In-Progress, Closed
  isActive    Boolean   @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  materialIssues MaterialIssue[]
}

model MaterialIssue {
  id          Int      @id @default(autoincrement())
  issueNo     String   @unique
  routeCardId Int
  issueDate   DateTime @default(now())
  isActive    Boolean  @default(true)
  createdBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  routeCard ProductionRouteCard @relation(fields: [routeCardId], references: [id])
  items     MaterialIssueItem[]
}

model MaterialIssueItem {
  id              Int   @id @default(autoincrement())
  materialIssueId Int
  productId       Int
  qtyRequested    Float
  qtyIssued       Float

  materialIssue MaterialIssue @relation(fields: [materialIssueId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}

model MaterialTransfer {
  id         Int      @id @default(autoincrement())
  mtaNo      String   @unique
  fromDept   String
  toDept     String
  productId  Int
  quantity   Float
  receivedBy String?
  status     String   @default("Pending") // Pending, Acknowledged
  isActive   Boolean  @default(true)
  createdBy  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProductionReport {
  id            Int      @id @default(autoincrement())
  reportDate    DateTime
  shift         String?
  machineNo     String?
  operatorName  String?
  productId     Int
  productionQty Float
  rejectionQty  Float    @default(0)
  remarks       String?
  createdBy     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
}

model JobOrder {
  id              Int       @id @default(autoincrement())
  jobOrderNo      String    @unique
  contractorName  String?
  processRequired String?
  rate            Float     @default(0)
  status          String    @default("Open") // Open, In-Progress, Closed
  isActive        Boolean   @default(true)
  createdBy       Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  items    JobOrderItem[]
  challans JobChallan[]
  bills    JobWorkBill[]
}

model JobOrderItem {
  id         Int   @id @default(autoincrement())
  jobOrderId Int
  productId  Int
  quantity   Float

  jobOrder JobOrder @relation(fields: [jobOrderId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}

model JobChallan {
  id          Int      @id @default(autoincrement())
  challanNo   String   @unique
  jobOrderId  Int
  vehicleNo   String?
  challanDate DateTime @default(now())
  status      String   @default("Sent") // Sent, Received
  isActive    Boolean  @default(true)
  createdBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobOrder JobOrder @relation(fields: [jobOrderId], references: [id])
}

model JobWorkBill {
  id           Int      @id @default(autoincrement())
  billNo       String   @unique
  jobOrderId   Int
  laborCharges Float    @default(0)
  gstAmount    Float    @default(0)
  totalAmount  Float    @default(0)
  status       String   @default("Unpaid") // Unpaid, Paid
  isActive     Boolean  @default(true)
  createdBy    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobOrder JobOrder @relation(fields: [jobOrderId], references: [id])
}

// ═══════════════════════════════════════════
// MODULE 4: PRODUCTION SIMULATION
// ═══════════════════════════════════════════

model SimulationRun {
  id                Int      @id @default(autoincrement())
  runDate           DateTime @default(now())
  shiftHours        Float    @default(10)
  workerCount       Int      @default(50)
  totalManHours     Float    @default(0)
  totalMachineHours Float    @default(0)
  daysRequired      Float    @default(0)
  laborCost         Float    @default(0)
  electricityCost   Float    @default(0)
  materialCost      Float    @default(0)
  totalCost         Float    @default(0)
  materialReadiness Float    @default(0) // percentage
  isSaved           Boolean  @default(false)
  createdBy         Int?
  createdAt         DateTime @default(now())

  inputs  SimulationInput[]
  results SimulationResult[]
}

model SimulationInput {
  id              Int   @id @default(autoincrement())
  simulationRunId Int
  productId       Int
  targetQty       Float

  simulationRun SimulationRun @relation(fields: [simulationRunId], references: [id])
}

model SimulationResult {
  id              Int    @id @default(autoincrement())
  simulationRunId Int
  materialName    String
  requiredQty     Float
  availableQty    Float
  shortfall       Float  @default(0)
  unitCost        Float  @default(0)
  totalCost       Float  @default(0)

  simulationRun SimulationRun @relation(fields: [simulationRunId], references: [id])
}

// ═══════════════════════════════════════════
// MODULE 5: FINANCE MANAGEMENT
// ═══════════════════════════════════════════

model JournalVoucher {
  id            Int       @id @default(autoincrement())
  voucherNo     String    @unique
  voucherDate   DateTime  @default(now())
  voucherType   String    @default("Journal") // Journal, Payment, Receipt, Contra, GST
  debitAccount  String
  creditAccount String
  amount        Decimal
  narration     String?
  isActive      Boolean   @default(true)
  createdBy     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
}

model BankReconciliation {
  id              Int      @id @default(autoincrement())
  bankAccount     String
  statementDate   DateTime
  systemBalance   Float    @default(0)
  bankBalance     Float    @default(0)
  unreconciledAmt Float    @default(0)
  status          String   @default("Pending") // Pending, Reconciled
  isActive        Boolean  @default(true)
  createdBy       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items BankReconciliationItem[]
}

model BankReconciliationItem {
  id                   Int      @id @default(autoincrement())
  bankReconciliationId Int
  transactionDate      DateTime
  description          String?
  systemAmount         Float    @default(0)
  bankAmount           Float    @default(0)
  isMatched            Boolean  @default(false)

  bankReconciliation BankReconciliation @relation(fields: [bankReconciliationId], references: [id])
}

model CreditCardStatement {
  id              Int      @id @default(autoincrement())
  cardNo          String
  statementMonth  String
  transactionDate DateTime
  merchant        String?
  amount          Float
  expenseHead     String?
  isActive        Boolean  @default(true)
  createdBy       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ═══════════════════════════════════════════
// MODULE 6: HR MANAGEMENT
// ═══════════════════════════════════════════

model Employee {
  id          Int       @id @default(autoincrement())
  empCode     String    @unique
  name        String
  designation String?
  department  String?
  mobile      String?
  joiningDate DateTime?
  basicSalary Decimal   @default(0)
  bankName    String?
  bankAccount String?
  ifscCode    String?
  isActive    Boolean   @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  salaryStructures EmployeeSalaryStructure[]
  salarySheets     EmployeeSalarySheet[]
  advanceMemos     EmployeeAdvanceMemo[]
  assetAllocations AssetAllocation[]
}

model SalaryHead {
  id       Int     @id @default(autoincrement())
  name     String  @unique // HRA, PF, DA, ESI, etc.
  type     String // Earning, Deduction
  isActive Boolean @default(true)
}

model EmployeeSalaryStructure {
  id            Int      @id @default(autoincrement())
  employeeId    Int
  effectiveDate DateTime
  basic         Float    @default(0)
  hra           Float    @default(0)
  da            Float    @default(0)
  pfPercent     Float    @default(12)
  esiPercent    Float    @default(0.75)
  allowances    Float    @default(0)
  isActive      Boolean  @default(true)
  createdBy     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model EmployeeSalarySheet {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  month           Int
  year            Int
  totalDays       Int
  presentDays     Int
  grossSalary     Float    @default(0)
  pfDeduction     Float    @default(0)
  esiDeduction    Float    @default(0)
  advanceRecovery Float    @default(0)
  otherDeductions Float    @default(0)
  netPay          Float    @default(0)
  status          String   @default("Draft") // Draft, Approved, Paid
  isActive        Boolean  @default(true)
  createdBy       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model EmployeeAdvanceMemo {
  id            Int      @id @default(autoincrement())
  employeeId    Int
  advanceDate   DateTime @default(now())
  amount        Float
  purpose       String?
  recoveryMonth String? // e.g. "2024-03"
  isRecovered   Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdBy     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

// ═══════════════════════════════════════════
// MODULE 7: QUALITY MANAGEMENT
// ═══════════════════════════════════════════

model MTSRecord {
  id         Int      @id @default(autoincrement())
  mtaRef     String?
  itemName   String
  qtyChecked Float
  status     String   @default("OK") // OK, Damaged
  remarks    String?
  isActive   Boolean  @default(true)
  createdBy  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PQCRecord {
  id           Int      @id @default(autoincrement())
  routeCardRef String?
  stageName    String?
  operatorName String?
  observations String?
  result       String   @default("Pass") // Pass, Fail
  isActive     Boolean  @default(true)
  createdBy    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PDIRecord {
  id                 Int      @id @default(autoincrement())
  soRef              String?
  boxNo              String?
  packagingCondition String?
  labelAccuracy      String? // Pass/Fail
  overallResult      String   @default("Pass") // Pass, Fail
  isActive           Boolean  @default(true)
  createdBy          Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model QRDRecord {
  id          Int      @id @default(autoincrement())
  rejectionId String   @unique
  itemName    String
  quantity    Float
  action      String // Scrap, Return, Rework, Downgrade
  remarks     String?
  isActive    Boolean  @default(true)
  createdBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ═══════════════════════════════════════════
// MODULE 8: STORES / WAREHOUSE
// ═══════════════════════════════════════════

model Warehouse {
  id          Int      @id @default(autoincrement())
  name        String
  address     String?
  managerName String?
  isActive    Boolean  @default(true)
  createdBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stocks WarehouseStock[]
}

model WarehouseStock {
  id          Int   @id @default(autoincrement())
  warehouseId Int
  productId   Int
  quantity    Float @default(0)
  value       Float @default(0)

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
}

model StockTransfer {
  id              Int      @id @default(autoincrement())
  transferNo      String   @unique
  fromWarehouseId Int
  toWarehouseId   Int
  productId       Int
  quantity        Float
  transferDate    DateTime @default(now())
  status          String   @default("Pending") // Pending, Completed
  isActive        Boolean  @default(true)
  createdBy       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DispatchSRV {
  id             Int       @id @default(autoincrement())
  srvNo          String    @unique
  partyName      String?
  itemName       String?
  quantity       Float     @default(0)
  returnExpected Boolean   @default(false)
  returnDate     DateTime?
  status         String    @default("Dispatched") // Dispatched, Returned
  isActive       Boolean   @default(true)
  createdBy      Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ═══════════════════════════════════════════
// MODULE 9: STATUTORY / GST
// ═══════════════════════════════════════════

model GSTMaster {
  id          Int      @id @default(autoincrement())
  hsnCode     String   @unique
  description String?
  igstPercent Float    @default(18)
  cgstPercent Float    @default(9)
  sgstPercent Float    @default(9)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GSTR1Entry {
  id              Int      @id @default(autoincrement())
  month           String
  invoiceNo       String
  customerGSTIN   String?
  taxableValue    Float    @default(0)
  taxAmount       Float    @default(0)
  state           String?
  transactionType String? // B2B, B2C
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GSTReconciliation {
  id             Int      @id @default(autoincrement())
  month          String
  vendorGSTIN    String?
  totalITC       Float    @default(0)
  matchedAmount  Float    @default(0)
  mismatchAmount Float    @default(0)
  status         String   @default("Pending") // Pending, Reconciled
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model GSTChallan {
  id          Int      @id @default(autoincrement())
  challanNo   String   @unique
  cpin        String?
  challanDate DateTime
  bankName    String?
  taxType     String // CGST, SGST, IGST
  amount      Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TDSDetail {
  id            Int      @id @default(autoincrement())
  section       String // 194C, 194J, etc.
  deducteeName  String
  paymentAmount Float
  tdsRate       Float
  tdsAmount     Float
  certificateNo String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TCSDetail {
  id           Int      @id @default(autoincrement())
  customerName String
  saleValue    Float
  tcsRate      Float    @default(0.1)
  tcsAmount    Float
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChequeBook {
  id          Int      @id @default(autoincrement())
  bankAccount String
  startLeafNo String
  endLeafNo   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leaves ChequeLeaf[]
}

model ChequeLeaf {
  id           Int       @id @default(autoincrement())
  chequeBookId Int
  leafNo       String
  status       String    @default("Blank") // Used, Cancelled, Blank
  issuedTo     String?
  issuedDate   DateTime?

  chequeBook ChequeBook @relation(fields: [chequeBookId], references: [id])
}

// ═══════════════════════════════════════════
// MODULE 10: LOGISTICS
// ═══════════════════════════════════════════

model Transporter {
  id        Int      @id @default(autoincrement())
  name      String
  ownerName String?
  mobile    String?
  gstin     String?
  isActive  Boolean  @default(true)
  createdBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transportOrders TransportOrder[]
  dispatchAdvice  DispatchAdvice[]
}

model TransportOrder {
  id            Int       @id @default(autoincrement())
  orderNo       String    @unique
  transporterId Int
  pickupDate    DateTime?
  destination   String?
  vehicleType   String?
  status        String    @default("Booked") // Booked, In-Transit, Delivered
  isActive      Boolean   @default(true)
  createdBy     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transporter Transporter @relation(fields: [transporterId], references: [id])
}

model FreightBill {
  id            Int      @id @default(autoincrement())
  billNo        String   @unique
  lrNo          String?
  freightAmount Float    @default(0)
  gstAmount     Float    @default(0)
  totalPayable  Float    @default(0)
  status        String   @default("Unpaid") // Unpaid, Paid
  isActive      Boolean  @default(true)
  createdBy     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ═══════════════════════════════════════════
// MODULE 11: CONTRACTORS HR
// ═══════════════════════════════════════════

model ContractorWorker {
  id             Int       @id @default(autoincrement())
  workerId       String    @unique
  contractorFirm String?
  workerName     String
  skillLevel     String    @default("Unskilled") // Skilled, Unskilled
  aadharNo       String?
  isActive       Boolean   @default(true)
  createdBy      Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  salarySheets ContractorSalarySheet[]
}

model ContractorSalaryHead {
  id        Int     @id @default(autoincrement())
  role      String  @unique // Helper, Welder, etc.
  dailyRate Float   @default(0)
  otRate    Float   @default(0)
  isActive  Boolean @default(true)
}

model ContractorSalarySheet {
  id          Int      @id @default(autoincrement())
  workerId    Int
  month       Int
  year        Int
  daysWorked  Int      @default(0)
  otHours     Float    @default(0)
  dailyRate   Float    @default(0)
  otRate      Float    @default(0)
  grossAmount Float    @default(0)
  tdsDeducted Float    @default(0)
  netPayable  Float    @default(0)
  status      String   @default("Draft") // Draft, Approved, Paid
  isActive    Boolean  @default(true)
  createdBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  worker ContractorWorker @relation(fields: [workerId], references: [id])
}

model ContractorAdvanceMemo {
  id             Int      @id @default(autoincrement())
  contractorName String
  advanceDate    DateTime @default(now())
  amount         Float
  remarks        String?
  isActive       Boolean  @default(true)
  createdBy      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ═══════════════════════════════════════════
// MODULE 12: MAINTENANCE
// ═══════════════════════════════════════════

model Tool {
  id                  Int      @id @default(autoincrement())
  assetCode           String   @unique
  toolName            String
  location            String?
  maintenanceInterval Int      @default(90) // days
  isActive            Boolean  @default(true)
  createdBy           Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  maintenanceCharts  ToolMaintenanceChart[]
  calibrationReports ToolCalibrationReport[]
  rectificationMemos ToolRectificationMemo[]
}

model ToolMaintenanceChart {
  id            Int       @id @default(autoincrement())
  toolId        Int
  scheduledDate DateTime
  taskList      String? // JSON: ["Greasing", "Cleaning"]
  status        String    @default("Scheduled") // Scheduled, Completed
  completedDate DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tool Tool @relation(fields: [toolId], references: [id])
}

model ToolCalibrationReport {
  id              Int      @id @default(autoincrement())
  toolId          Int
  calibrationDate DateTime
  standardValue   Float?
  actualValue     Float?
  result          String   @default("Pass") // Pass, Fail
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tool Tool @relation(fields: [toolId], references: [id])
}

model ToolRectificationMemo {
  id         Int      @id @default(autoincrement())
  toolId     Int
  issue      String?
  sparesUsed String?
  cost       Float    @default(0)
  technician String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tool Tool @relation(fields: [toolId], references: [id])
}

// ═══════════════════════════════════════════
// MODULE 13: ASSET MANAGEMENT
// ═══════════════════════════════════════════

model Asset {
  id               Int       @id @default(autoincrement())
  assetTag         String    @unique
  name             String
  assetGroup       String? // IT, Plant, Furniture
  purchaseDate     DateTime?
  purchaseValue    Float     @default(0)
  currentValue     Float     @default(0)
  depreciationRate Float     @default(10) // percentage per year
  isActive         Boolean   @default(true)
  createdBy        Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  additions     AssetAddition[]
  allocations   AssetAllocation[]
  sales         AssetSale[]
  depreciations AssetDepreciation[]
}

model AssetAddition {
  id               Int       @id @default(autoincrement())
  assetId          Int
  invoiceRef       String?
  installationDate DateTime?
  depreciationRate Float     @default(10)
  isActive         Boolean   @default(true)
  createdBy        Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])
}

model AssetAllocation {
  id           Int       @id @default(autoincrement())
  assetId      Int
  employeeId   Int
  department   String?
  dateAssigned DateTime  @default(now())
  dateReturned DateTime?
  isActive     Boolean   @default(true)
  createdBy    Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  asset    Asset    @relation(fields: [assetId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

model AssetSale {
  id        Int      @id @default(autoincrement())
  assetId   Int
  saleDate  DateTime
  saleValue Float    @default(0)
  bookValue Float    @default(0)
  isActive  Boolean  @default(true)
  createdBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])
}

model AssetDepreciation {
  id                 Int      @id @default(autoincrement())
  assetId            Int
  year               Int
  openingBalance     Float    @default(0)
  depreciationAmount Float    @default(0)
  closingBalance     Float    @default(0)
  createdAt          DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])
}

// ═══════════════════════════════════════════
// DOCUMENT AUTO-NUMBERING TRACKER
// ═══════════════════════════════════════════

model DocSequence {
  id      Int    @id @default(autoincrement())
  docType String @unique // INQ, QT, SO, INV, PO, GRN, etc.
  prefix  String
  year    Int
  lastNo  Int    @default(0)
}
